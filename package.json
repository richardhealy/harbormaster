{
  "name": "harbormaster",
  "version": "0.1.0",
  "description": "Coordination layer for a fleet of AI coding agents — schedules work, integrates optimistically, and ships under release management.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'test/**/*.ts' --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/core": "^6.1.2",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.4.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "semver": "^7.6.3",
    "winston": "^3.14.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.6",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "testMatch": ["**/*.test.ts"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["src/**/*.ts"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "^@octokit/(.+)$": "<rootDir>/test/__mocks__/@octokit/$1"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
