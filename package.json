{
  "name": "harbormaster",
  "version": "0.1.0",
  "description": "Coordination layer for a fleet of AI coding agents — conflict-aware scheduler, optimistic merge queue, release lifecycle.",
  "main": "dist/app.js",
  "bin": {
    "harbormaster": "dist/agent-iface/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/app.ts",
    "start": "node dist/app.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "migrate": "ts-node src/db/migrate.ts"
  },
  "keywords": ["agents", "merge-queue", "scheduler", "release-management"],
  "license": "MIT",
  "dependencies": {
    "@octokit/app": "^15.1.0",
    "@octokit/rest": "^21.1.0",
    "@octokit/webhooks": "^14.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0",
    "semver": "^7.6.3",
    "simple-git": "^3.27.0",
    "winston": "^3.14.2",
    "yargs": "^17.7.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.5.5",
    "@types/pg": "^8.11.10",
    "@types/semver": "^7.5.8",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
