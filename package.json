{
  "name": "harbormaster",
  "version": "0.1.0",
  "description": "Coordination layer for a fleet of AI coding agents — conflict-aware scheduling, optimistic merge queue integration, and on-the-record release management",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'tests/**/*.ts' --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@linear/sdk": "^26.0.0",
    "@octokit/app": "^15.1.1",
    "@octokit/core": "^6.1.2",
    "@octokit/rest": "^21.0.2",
    "@octokit/webhooks": "^13.4.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "pg": "^8.13.0",
    "semver": "^7.6.3",
    "simple-git": "^3.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/semver": "^7.5.8",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  }
}
