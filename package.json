{
  "name": "harbormaster",
  "version": "0.1.0",
  "description": "Coordination layer for a fleet of AI coding agents — conflict-aware scheduler, optimistic merge queue, release lifecycle",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/app": "^15.1.0",
    "@octokit/webhooks": "^13.4.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "postgres": "^3.4.4",
    "semver": "^7.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/semver": "^7.5.8",
    "@vitest/coverage-v8": "^2.0.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.3"
  }
}
