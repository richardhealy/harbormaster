{
  "name": "harbormaster",
  "version": "0.1.0",
  "description": "Coordination layer for AI coding agents: conflict-aware scheduling, optimistic integration, release lifecycle",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest --forceExit",
    "test:ci": "jest --forceExit --ci --coverage",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "migrate": "ts-node src/db/migrate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/app": "^14.0.2",
    "@octokit/rest": "^20.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.11.5",
    "semver": "^7.6.2",
    "simple-git": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/semver": "^7.5.8",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
